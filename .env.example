# Emby 服务器配置
# Emby Server URL (例如: http://localhost:8096)
VITE_EMBY_SERVER_URL=http://localhost:8096

# 弹幕 API 配置
# Danmaku API URL (例如: https://api.dandanplay.net)
VITE_DANMAKU_API_URL=https://api.dandanplay.net

# 应用配置
# 应用版本
VITE_APP_VERSION=1.0.0

# 应用名称
VITE_APP_NAME=Emby UI

# 客户端标识
VITE_CLIENT_NAME=Emby Web

# ASSRT 字幕搜索
# 前端是否启用 ASSRT 搜索入口（需要同时配置下方服务端代理 token）
VITE_ASSRT_ENABLED=false

# ASSRT 反向代理路径
VITE_ASSRT_PROXY_URL=/api/assrt

# ASSRT 服务端 token（仅供 Vite/Nginx 代理读取，不会暴露给前端）
ASSRT_TOKEN=

# OpenSubtitles 字幕搜索
# 前端是否启用字幕搜索入口（需要同时配置下方服务端代理密钥）
VITE_OPENSUBTITLES_ENABLED=false

# OpenSubtitles 反向代理路径
VITE_OPENSUBTITLES_PROXY_URL=/api/opensubtitles

# OpenSubtitles 服务端密钥（仅供 Vite/Nginx 代理读取，不会暴露给前端）
OPENSUBTITLES_API_KEY=

# OpenSubtitles 请求使用的 User-Agent
OPENSUBTITLES_USER_AGENT=Embience v1.0.0
